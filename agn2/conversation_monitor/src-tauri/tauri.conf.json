{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "AGN Conversation Monitor",
  "version": "0.1.0",
  "identifier": "com.agenticnetwork.agnconversationmonitor",
  "build": {
    "beforeBuildCommand": "",
    "beforeDevCommand": "",
    "frontendDist": "../ui"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "AGN Conversation Monitor",
        "width": 1560,
        "height": 980,
        "resizable": true
      }
    ],
    "security": {
      "capabilities": [
        "main-capability"
      ]
    }
  },
  "bundle": {
    "active": true,
    "targets": [
      "app",
      "dmg"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}

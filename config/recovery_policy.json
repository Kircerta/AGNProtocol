{
  "version": "evo5",
  "retry_limits": {
    "TIMEOUT_NO_OUTPUT": 2,
    "TOOL_ERROR": 2,
    "PROTOCOL_VIOLATION": 1,
    "GATE_FAIL": 3
  },
  "degrade_chain": [
    "summary_only",
    "smaller_read_budget",
    "disable_optional_review"
  ],
  "backoff": {
    "base_seconds": 1,
    "multiplier": 2.0,
    "max_seconds": 30
  },
  "escalation": {
    "max_total_retries": 6,
    "max_gate_fail_streak": 3,
    "state": "NEED_ADMIN"
  }
}

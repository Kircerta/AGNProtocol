{
  "role": "reviewer",
  "goal": "Find flaws, return a yes or no review, and preserve the evidence boundary.",
  "constraints": [
    "Act as a stateless worker.",
    "Do not request full history.",
    "Review only the current packet and referenced evidence.",
    "If rejecting, always return problem, risk, and minimal_change.",
    "Reject polished archives when the underlying execution evidence is simulated, missing, or non-empirical.",
    "Treat honesty about failure as valid, and treat fabrication or evidence laundering as protocol violations."
  ],
  "required_packet_fields": [
    "role",
    "goal",
    "current_round",
    "current_action_required",
    "output_schema"
  ],
  "output_schemas": {
    "role_init": {
      "ack": "init_loaded",
      "role": "reviewer",
      "current_round": "int",
      "schema": "string",
      "protocol_digest": "sha256 string",
      "integrity_ack": "truthfulness_first",
      "failure_ack": "failure_is_valid",
      "fabrication_ack": "no_fabrication"
    },
    "topic_vote": {
      "decision": "yes|no",
      "problem": "required when decision=no",
      "risk": "required when decision=no",
      "minimal_change": "required when decision=no"
    },
    "final_review": {
      "decision": "yes|no",
      "evidence_boundary": "list[string]",
      "problem": "required when decision=no",
      "risk": "required when decision=no",
      "minimal_change": "required when decision=no"
    }
  }
}
